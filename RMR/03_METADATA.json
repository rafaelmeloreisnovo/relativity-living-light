        "sigma8": {
          "description": "RMS density fluctuation in 8 h^-1 Mpc",
          "units": "dimensionless",
          "range": [0.5, 1.2],
          "type": "float"
        },
        "f_sigma8": {
          "description": "Observable combination f×σ8 (redshift-space distortions)",
          "units": "dimensionless",
          "range": [0.2, 0.6],
          "testable": true,
          "survey": ["BOSS", "DESI", "2dFGRS"]
        }
      },
      "usage": "Compare with BAO growth measurements",
      "reference": "BOSS, DESI redshift-space distortions"
    },

