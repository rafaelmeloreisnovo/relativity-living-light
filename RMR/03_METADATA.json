    "reference_models/unified_fiducial_grid.csv": {
      "description": "Grid of fiducial cosmological parameters and outputs",
      "n_rows": 1024,
      "n_columns": 17,
      "generated_by": "01_friedmann_solver.py",
      "columns": {
        "Omega_s0": {
          "description": "Superposition density parameter today",
          "units": "dimensionless",
          "range": [0.01, 0.25],
          "type": "float"
        },
        "z_t": {
          "description": "Transition redshift (DE to DM)",
          "units": "dimensionless",
          "range": [0.1, 3.0],
          "type": "float"
        },
        "w_t": {
          "description": "Transition width (smoothness parameter)",
          "units": "dimensionless",
          "range": [0.1, 1.0],
          "type": "float"
        },
        "Omega_B0": {
          "description": "Magnetic field density today",
          "units": "dimensionless",
          "range": [1e-6, 1e-5],
          "type": "float"
        },
        "Omega_P0": {
          "description": "Plasma density today",
          "units": "dimensionless",
          "range": [1e-6, 1e-5],
          "type": "float"
        },
        "H_0": {
          "description": "Hubble parameter today",
          "units": "km/s/Mpc",
          "range": [65, 75],
          "type": "float"
        },
        "H_z_0.5": {
          "description": "Hubble parameter at z=0.5",
          "units": "km/s/Mpc",
          "type": "float"
        },
        "H_z_1.0": {
          "description": "Hubble parameter at z=1.0",
          "units": "km/s/Mpc",
          "type": "float"
        },
        "mu_z_0.5": {
          "description": "Distance modulus at z=0.5",
          "units": "magnitude",
          "type": "float"
        },
        "mu_z_1.0": {
          "description": "Distance modulus at z=1.0",
          "units": "magnitude",
          "type": "float"
        },
        "f_z_0.5": {
          "description": "Coherence fraction at z=0.5",
          "units": "dimensionless",
          "range": [0.0, 1.0],
          "type": "float"
        },
        "f_z_1.0": {
          "description": "Coherence fraction at z=1.0",
          "units": "dimensionless",
          "range": [0.0, 1.0],
          "type": "float"
        },
        "w_eff_z_0.5": {
          "description": "Effective equation of state at z=0.5",
          "units": "dimensionless",
          "range": [-1.0, 0.33],
          "type": "float"
        },
        "w_eff_z_1.0": {
          "description": "Effective equation of state at z=1.0",
          "units": "dimensionless",
          "range": [-1.0, 0.33],
          "type": "float"
        },
        "chi2_SNe": {
          "description": "χ² against Pantheon+ SNe Ia",
          "units": "dimensionless",
          "type": "float"
        },
        "chi2_BAO": {
          "description": "χ² against eBOSS BAO",
          "units": "dimensionless",
          "type": "float"
        },
        "chi2_total": {
          "description": "Combined χ² (SNe + BAO + CMB)",
          "units": "dimensionless",
          "type": "float"
        }
      },
      "usage": "Reference grid for parameter space exploration",
      "how_to_load": "pd.read_csv('unified_fiducial_grid.csv')"
    },

