{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rll.local/schemas/orbital_shape_angular_momentum.schema.json",
  "title": "RLL Orbital Shape Angular Momentum Result",
  "type": "object",
  "required": [
    "schema_version",
    "module",
    "input_file",
    "data_status",
    "claim_allowed",
    "claim_boundary",
    "formulas",
    "items",
    "required_next_data",
    "safe_conclusion",
    "status"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "module": {"const": "orbital_shape_angular_momentum"},
    "input_file": {"type": "string"},
    "data_status": {"type": "string"},
    "claim_allowed": {"const": false},
    "claim_boundary": {"type": "string"},
    "formulas": {"type": "object"},
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["record_id", "body_system", "calculations_v1", "status", "claim_allowed"],
        "properties": {
          "record_id": {"type": "string"},
          "body_system": {"type": "string"},
          "calculations_v1": {
            "type": "object",
            "required": [
              "specific_orbital_angular_momentum_km2_s",
              "mean_orbital_speed_proxy_km_s",
              "spin_angular_momentum_proxy_kg_m2_s",
              "rotation_rate_rad_s",
              "computed_flattening_from_radii"
            ],
            "properties": {
              "specific_orbital_angular_momentum_km2_s": {"type": "number"},
              "mean_orbital_speed_proxy_km_s": {"type": "number"},
              "spin_angular_momentum_proxy_kg_m2_s": {"type": "number"},
              "rotation_rate_rad_s": {"type": "number"},
              "computed_flattening_from_radii": {"type": "number"}
            },
            "additionalProperties": true
          },
          "status": {"type": "string"},
          "claim_allowed": {"const": false}
        },
        "additionalProperties": true
      }
    },
    "required_next_data": {"type": "array", "items": {"type": "string"}},
    "safe_conclusion": {"type": "string"},
    "status": {"type": "string"}
  },
  "additionalProperties": true
}
