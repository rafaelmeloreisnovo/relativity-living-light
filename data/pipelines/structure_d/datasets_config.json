{
  "default_profile": "structure_d_default",
  "profiles": {
    "structure_d_default": {
      "run_name": "structure_d_default",
      "active_datasets": [
        "hz",
        "fsigma8"
      ]
    },
    "structure_d_real_validation": {
      "run_name": "structure_d_real_validation",
      "active_datasets": [
        "real_hz",
        "real_bao",
        "real_cmb_shift"
      ]
    },
    "structure_d_partial_real": {
      "run_name": "structure_d_partial_real",
      "active_datasets": [
        "real_hz",
        "real_bao"
      ]
    },
    "structure_d_synthetic_advanced": {
      "run_name": "structure_d_synthetic_advanced",
      "active_datasets": [
        "hz_cov_synth",
        "fsigma8_cov_synth"
      ]
    }
  },
  "datasets": {
    "hz": {
      "format": "csv",
      "path": "data/inputs/structure_d/Hz.csv",
      "observable": "Hz",
      "error_model": "errors",
      "columns": {
        "z": "z",
        "value": "Hz",
        "error": "sigma"
      },
      "metadata": {
        "survey": "inputs_structure_d",
        "redshift_range": "[0.0, 3.0]",
        "reference": "local_input"
      },
      "duplicate_z_policy": "erro"
    },
    "fsigma8": {
      "format": "csv",
      "path": "data/inputs/structure_d/fsigma8.csv",
      "observable": "fs8",
      "error_model": "errors",
      "columns": {
        "z": "z",
        "value": "fs8",
        "error": "sigma"
      },
      "metadata": {
        "survey": "inputs_structure_d",
        "redshift_range": "[0.0, 3.0]",
        "reference": "local_input"
      },
      "duplicate_z_policy": "erro"
    },
    "real_hz": {
      "format": "csv",
      "path": "data/real/Hz_data_real.csv",
      "observable": "Hz",
      "error_model": "errors",
      "columns": {
        "z": "z",
        "value": "H_obs",
        "error": "sigma_H"
      },
      "metadata": {
        "survey": "CC+BAO_Lya",
        "redshift_range": "[0.07, 2.34]",
        "reference": "Moresco2022+BOSS"
      },
      "duplicate_z_policy": "erro"
    },
    "real_bao": {
      "format": "csv",
      "path": "data/real/BAO_data_real.csv",
      "observable": "DV_over_rs",
      "error_model": "errors",
      "columns": {
        "z": "z_eff",
        "value": "DV_over_rs",
        "error": "sigma"
      },
      "metadata": {
        "survey": "BOSS_DR12+DESI2024",
        "redshift_range": "[0.106, 2.33]",
        "reference": "BOSS_DR12_DESI2024"
      },
      "duplicate_z_policy": "erro",
      "z_order_policy": "sort"
    },
    "real_cmb_shift": {
      "format": "json_scalars",
      "path": "data/real/CMB_shift_real.json",
      "observable": "CMB_shift",
      "error_model": "errors",
      "keys": {
        "values": [
          "R_obs",
          "la_obs"
        ],
        "errors": [
          "R_sig",
          "la_sig"
        ]
      },
      "metadata": {
        "survey": "Planck2018",
        "redshift_range": "z=1089.92",
        "reference": "Planck2018_VI"
      }
    },
    "hz_cov_synth": {
      "format": "csv",
      "path": "data/inputs/structure_d/Hz_cov.csv",
      "observable": "Hz",
      "error_model": "covariance",
      "columns": {
        "z": "z",
        "value": "Hz",
        "covariance": null
      },
      "covariance_path": "data/inputs/structure_d/Hz_cov_matrix.csv",
      "metadata": {
        "survey": "inputs_structure_d_covariance",
        "redshift_range": "[0.0, 3.0]",
        "reference": "local_input_covariance"
      }
    },
    "fsigma8_cov_synth": {
      "format": "csv",
      "path": "data/inputs/structure_d/fsigma8_cov.csv",
      "observable": "fs8",
      "error_model": "covariance",
      "columns": {
        "z": "z",
        "value": "fs8",
        "covariance": null
      },
      "covariance_path": "data/inputs/structure_d/fsigma8_cov_matrix.csv",
      "metadata": {
        "survey": "inputs_structure_d_covariance",
        "redshift_range": "[0.0, 3.0]",
        "reference": "local_input_covariance"
      }
    },
    "real_fsigma8": {
      "format": "csv",
      "path": "data/real/cosmology/fsigma8_growth_real.csv",
      "observable": "fs8",
      "error_model": "errors",
      "columns": {
        "z": "z",
        "value": "fs8",
        "error": "sigma"
      },
      "metadata": {
        "survey": "RSD_growth_compilation",
        "redshift_range": "[0.02, 0.78]",
        "reference": "Hudson_Turnbull_2013+Beutler_2012+compiled_fsigma8_table",
        "real_data_status": "materialized_real"
      },
      "duplicate_z_policy": "primeira_ocorrencia"
    },
    "real_desi_dr2_bao": {
      "format": "csv",
      "path": "data/real/cosmology/desi_dr2_bao_primary_points.csv",
      "observable": "DESI_DR2_BAO_ratio",
      "error_model": "errors",
      "columns": {
        "z": "z_eff",
        "value": "value",
        "error": "sigma"
      },
      "metadata": {
        "survey": "DESI_DR2_BAO_2025",
        "redshift_range": "[0.295, 2.330]",
        "reference": "DESI_DR2_Results_II_Table_IV",
        "real_data_status": "materialized_real",
        "covariance_summary": "data/real/cosmology/desi_dr2_bao_covariance_summary.csv"
      },
      "duplicate_z_policy": "primeira_ocorrencia",
      "z_order_policy": "sort"
    }
  },
  "validation": {
    "min_points_with_z": 3
  }
}
