{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relativity-living-light.local/schemas/yml_role.schema.json",
  "title": "RLL YML role metadata",
  "type": "object",
  "additionalProperties": true,
  "required": ["meta"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "required": ["yml_role", "execution_level", "claim_allowed"],
      "properties": {
        "yml_role": {
          "type": "string",
          "enum": ["workflow", "config", "manifest", "route", "ledger", "result", "example", "schema", "iml"]
        },
        "execution_level": {
          "type": "string",
          "enum": ["E0", "E1", "E2", "E3", "E4", "E5"]
        },
        "runs_by_itself": {
          "type": "boolean"
        },
        "consumed_by": {
          "type": "array",
          "items": {"type": "string"}
        },
        "produces": {
          "type": "array",
          "items": {"type": "string"}
        },
        "claim_allowed": {
          "type": "boolean"
        },
        "baseline_required": {
          "type": "boolean"
        },
        "falsifier_required": {
          "type": "boolean"
        },
        "negative_result_policy": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"claim_allowed": {"const": true}},
            "required": ["claim_allowed"]
          },
          "then": {
            "properties": {
              "baseline_required": {"const": true},
              "falsifier_required": {"const": true}
            },
            "required": ["baseline_required", "falsifier_required", "negative_result_policy"]
          }
        }
      ]
    }
  }
}
