{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/rll/omega_relation.schema.json",
  "title": "OmegaRelation",
  "description": "Structural contract for a weighted connection between OmegaNodes. Canonical formula: Peso_relação = Evidência × Coerência × Reprodutibilidade. Temporal stability is tracked separately and does not rewrite the canonical formula.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "relation_id",
    "source_node",
    "target_node",
    "relation_type",
    "evidence",
    "coherence",
    "reproducibility",
    "temporal_stability",
    "weight",
    "status",
    "created_at"
  ],
  "properties": {
    "relation_id": {"type": "string", "minLength": 1},
    "source_node": {"type": "string", "minLength": 1},
    "target_node": {"type": "string", "minLength": 1},
    "relation_type": {"type": "string", "minLength": 1},
    "evidence": {"type": "number", "minimum": 0, "maximum": 1},
    "coherence": {"type": "number", "minimum": 0, "maximum": 1},
    "reproducibility": {"type": "number", "minimum": 0, "maximum": 1},
    "temporal_stability": {"type": "number", "minimum": 0, "maximum": 1},
    "weight": {"type": "number", "minimum": 0, "maximum": 1},
    "status": {
      "type": "string",
      "enum": ["fact", "hypothesis", "metaphor", "evidence", "token_vazio", "decision"]
    },
    "created_at": {"type": "string", "format": "date-time"}
  }
}
