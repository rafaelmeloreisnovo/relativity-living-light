{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RLL Watch Configuration",
  "type": "object",
  "required": ["source", "vectors"],
  "properties": {
    "source": {
      "type": "object",
      "required": ["name", "role", "academic_weight"],
      "properties": {
        "name": {"type": "string"},
        "role": {"type": "string"},
        "academic_weight": {
          "type": "string",
          "enum": ["primary_source", "secondary_source", "tertiary_source", "unverified"]
        },
        "primary_source_required": {"type": "boolean"},
        "evidence_level": {
          "type": "string",
          "enum": ["radar", "conceptual", "partial_real", "real_validated"]
        },
        "last_reviewed": {
          "type": "string",
          "format": "date"
        }
      },
      "additionalProperties": true
    },
    "vectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "rll_module"],
        "properties": {
          "id": {"type": "string"},
          "rll_module": {"type": "string"},
          "status": {"type": "string"},
          "datasets": {"type": "array", "items": {"type": "string"}},
          "required_metrics": {"type": "array", "items": {"type": "string"}},
          "variables": {"type": "array", "items": {"type": "string"}},
          "targets": {"type": "array", "items": {"type": "string"}},
          "warning": {"type": "string"},
          "claim_boundary": {"type": "string"},
          "validation_output": {"type": ["string", "null"]},
          "primary_source_required": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
