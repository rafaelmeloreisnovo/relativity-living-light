{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/rll/omega_node.schema.json",
  "title": "OmegaNode",
  "description": "Structural contract for a versioned semantic cell in the RAFAELIA Omega architecture. Scores are routing metadata and do not promote a claim to scientific fact.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "node_id",
    "kind",
    "value",
    "semantic_vector_ref",
    "relation_weight",
    "evidence_score",
    "validation_score",
    "confidence",
    "parent",
    "timestamp",
    "hash"
  ],
  "properties": {
    "node_id": {"type": "string", "minLength": 1},
    "kind": {"type": "string", "minLength": 1},
    "value": {},
    "semantic_vector_ref": {"type": ["string", "null"]},
    "relation_weight": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_score": {"type": "number", "minimum": 0, "maximum": 1},
    "validation_score": {"type": "number", "minimum": 0, "maximum": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "parent": {"type": ["string", "null"]},
    "timestamp": {"type": "string", "format": "date-time"},
    "hash": {"type": "string", "minLength": 1}
  }
}
