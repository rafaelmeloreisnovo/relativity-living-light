{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/rll/omega_artifact.schema.json",
  "title": "OmegaArtifact",
  "description": "Structural contract for a living knowledge unit in the RAFAELIA Omega architecture. This schema records provenance, epistemic status, evidence links and revision gates; it does not validate scientific claims.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "artifact_id",
    "title",
    "origin_question",
    "context",
    "method",
    "hypotheses",
    "evidence",
    "relations",
    "revisions",
    "limitations",
    "status",
    "next_question",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "artifact_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "origin_question": {"type": "string", "minLength": 1},
    "context": {"type": "string", "minLength": 1},
    "method": {"type": "string", "minLength": 1},
    "hypotheses": {
      "type": "array",
      "items": {"type": "string"}
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["evidence_id", "status"],
        "properties": {
          "evidence_id": {"type": "string", "minLength": 1},
          "status": {"$ref": "#/$defs/epistemic_status"},
          "source_ref": {"type": "string"},
          "hash": {"type": "string"}
        }
      }
    },
    "relations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "revisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["revision_id", "timestamp", "summary"],
        "properties": {
          "revision_id": {"type": "string", "minLength": 1},
          "timestamp": {"type": "string", "format": "date-time"},
          "summary": {"type": "string", "minLength": 1}
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "status": {"$ref": "#/$defs/epistemic_status"},
    "next_question": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "epistemic_status": {
      "type": "string",
      "enum": [
        "fact",
        "hypothesis",
        "metaphor",
        "evidence",
        "token_vazio",
        "decision"
      ]
    }
  }
}
