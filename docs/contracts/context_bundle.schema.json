{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/instituto-Rafael/relativity-living-light/docs/contracts/context_bundle.schema.json",
  "title": "Context Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "bundle_id", "chunks", "assembled_at"],
  "properties": {
    "schema": {"const": "rafaelia.context_bundle.v1"},
    "bundle_id": {"type": "string", "minLength": 1},
    "chunks": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "conversation_chunk.schema.json"}
    },
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "assembled_at": {"type": "string", "format": "date-time"}
  }
}
